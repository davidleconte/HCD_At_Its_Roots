{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Client Request Latency (p99) — Write",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "cassandra_client_request_latency_99thpercentile{scope=\"Write\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Client Request Latency (p99) — Read",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "cassandra_client_request_latency_99thpercentile{scope=\"Read\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Thread Pool — MutationStage Active",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "cassandra_threadpool_request_activetasks{pool=\"MutationStage\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } }
      }
    },
    {
      "title": "Thread Pool — MutationStage Pending",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "cassandra_threadpool_request_pendingtasks{pool=\"MutationStage\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      }
    },
    {
      "title": "Thread Pool — ReadStage Active",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "cassandra_threadpool_request_activetasks{pool=\"ReadStage\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } }
      }
    },
    {
      "title": "Compaction — Pending Tasks",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "cassandra_compaction_pendingtasks",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Dropped Messages (Total)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(cassandra_dropped_dropped) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Hints — Stored Count",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "cassandra_hints_hints_created",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
