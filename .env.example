# HCD Docker Cluster Configuration
# Copy this file to .env and customize as needed

# Cluster Configuration
CASSANDRA_CLUSTER_NAME=HCDCluster

# Networking
# It is recommended to have at least one seed per datacenter.
# Node 1 (dc1) at 172.28.0.2, Node 4 (dc2) at 172.28.0.5
CASSANDRA_SEEDS=172.28.0.2,172.28.0.5

# Per-node settings (set automatically in docker-compose.yml; override only for custom topologies)
# CASSANDRA_LISTEN_ADDRESS=172.28.0.2
# CASSANDRA_BROADCAST_ADDRESS=172.28.0.2
# CASSANDRA_RPC_ADDRESS=0.0.0.0
# CASSANDRA_ENDPOINT_SNITCH=GossipingPropertyFileSnitch
# CASSANDRA_DC=dc1
# CASSANDRA_RACK=rack1

# JVM Memory Settings (per node)
# For demo purposes on a single laptop, 512M is usually sufficient.
MAX_HEAP_SIZE=512M
HEAP_NEWSIZE=100M

# Additional JVM options (e.g., JMX Prometheus exporter agent)
# JVM_EXTRA_OPTS=-javaagent:/opt/hcd/jmx_prometheus_javaagent.jar=9404:/opt/hcd/jmx-exporter.yml

# Optional: Enable JMX for monitoring (not recommended in production)
# JMX_PORT=7199

# Cluster readiness check (used by 'make wait')
# EXPECTED_NODES=6

# Grafana credentials (used with --profile monitoring)
# GF_ADMIN_USER=admin
# GF_ADMIN_PASSWORD=admin

# MinIO credentials (used with --profile ransomware)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
